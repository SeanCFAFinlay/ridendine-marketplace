# ===========================================
# RIDENDINE ENVIRONMENT VARIABLES
# ===========================================
# Copy this file to .env.local (per app or repo root) and fill in your values.
# NEVER commit real credentials to version control.
#
# Canonical matrix: docs/ENVIRONMENT_VARIABLES.md
# Deployment order: docs/RUNBOOK_DEPLOY.md

# Node (usually set by host; local override optional)
# NODE_ENV=development

# Supabase Configuration
# Get these from your Supabase project dashboard: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Database (for migrations/direct access)
# Get from Supabase: Settings > Database > Connection string
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-ref.supabase.co:5432/postgres

# Application URLs (adjust for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CHEF_ADMIN_URL=http://localhost:3001
# Optional override for chef signup CTAs (defaults to NEXT_PUBLIC_CHEF_ADMIN_URL/auth/signup)
# NEXT_PUBLIC_CHEF_PORTAL_SIGNUP_URL=http://localhost:3001/auth/signup
NEXT_PUBLIC_OPS_ADMIN_URL=http://localhost:3002
NEXT_PUBLIC_DRIVER_APP_URL=http://localhost:3003

# Stripe Configuration
# Get from Stripe Dashboard: Developers > API keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Google Maps (for delivery tracking)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-key

# Email (Resend)
# RESEND_API_KEY=re_...

# Engine Processor Authentication
# Used by automated SLA and expired-offer processors
# Generate with: openssl rand -hex 32
ENGINE_PROCESSOR_TOKEN=your_processor_token_here

# Vercel Cron Secret (Vercel auto-sends this as Authorization header for cron jobs)
# Set this in your Vercel project environment variables
CRON_SECRET=your_vercel_cron_secret_here

# Error Monitoring (Sentry)
# Create a project at sentry.io and paste the DSN here
# NEXT_PUBLIC_SENTRY_DSN=https://your-key@o123.ingest.sentry.io/456

# Feature Flags
NEXT_PUBLIC_ENABLE_REVIEWS=true
NEXT_PUBLIC_ENABLE_DRIVER_TRACKING=true

# Development Bypass (set to false in production)
BYPASS_AUTH=false
