{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm build",
  "crons": [
    {
      "path": "/api/engine/processors/sla",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/engine/processors/expired-offers",
      "schedule": "* * * * *"
    }
  ]
}
