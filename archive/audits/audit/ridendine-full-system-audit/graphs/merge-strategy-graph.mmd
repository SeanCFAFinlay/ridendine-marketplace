        UNI_PACKAGES["Shared packages\n(consolidated)"]

        UNI_PUBLIC --> UNI_SUPABASE
        UNI_ADMIN --> UNI_SUPABASE
        UNI_PUBLIC --> UNI_PACKAGES
        UNI_ADMIN --> UNI_PACKAGES
    end

    subgraph Benefits["Expected Benefits"]
        B1["Eliminate 4x auth\nduplication"]
