        DUP4["Supabase client\nconfiguration x4"]
    end

    subgraph Phase1["Phase 1: Package Consolidation (Weeks 1-2)"]
        P1_ENGINE["Centralize all\nbusiness logic in\n@ridendine/engine"]
        P1_AUTH["Single auth\nmiddleware in\n@ridendine/auth"]
        P1_NOTIFY["Unified notifications\nin @ridendine/notifications"]
        P1_TYPES["Canonical types\nin @ridendine/types"]

        P1_ENGINE --> P1_AUTH
        P1_AUTH --> P1_NOTIFY
        P1_NOTIFY --> P1_TYPES
    end

    subgraph Phase2["Phase 2: Route Normalization (Weeks 3-4)"]
        P2_ROUTES["Standardize API\nroute patterns\nacross all apps"]
        P2_ERRORS["Unified error\nhandling middleware"]
        P2_LOGGING["Centralized\naudit logging"]

        P2_ROUTES --> P2_ERRORS
        P2_ERRORS --> P2_LOGGING
    end

    subgraph Phase3["Phase 3: Optional Merge (Weeks 5-8)"]
        P3A["Option A: Keep 4 apps\nbut share more code\n(Lower risk)"]
        P3B["Option B: Merge to\n2 apps (public + admin)\n(Medium risk)"]
        P3C["Option C: Single app\nwith role routing\n(Higher risk)"]
    end

    subgraph Unified["Proposed Unified Architecture (Option B)"]
        UNI_PUBLIC["apps/web\nPublic domain\nCustomer + Chef signup\nDriver signup"]
        UNI_ADMIN["apps/admin\nAdmin domain\nChef + Ops + Driver\nRole-based routing"]
