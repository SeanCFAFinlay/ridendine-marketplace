graph TD
    subgraph Current["Current Architecture (4-App Split)"]
        CUR_WEB["apps/web\nridendine.ca\n22 pages\nCustomer only"]
        CUR_CHEF["apps/chef-admin\nchef.ridendine.ca\n11 pages\nChef only"]
        CUR_OPS["apps/ops-admin\nops.ridendine.ca\n18 pages\nOps only"]
        CUR_DRIVER["apps/driver-app\ndriver.ridendine.ca\n5 pages\nDriver only"]

        CUR_WEB -.->|"4 separate\nVercel projects"| CUR_CHEF
        CUR_CHEF -.-> CUR_OPS
        CUR_OPS -.-> CUR_DRIVER
    end

